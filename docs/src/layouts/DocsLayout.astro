---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { NavItem } from "../data/nav";

interface Props {
  title: string;
  description: string;
  current?: string;
  nav?: NavItem[];
  section?: "features" | "docs" | "about";
  breadcrumb?: { label: string; href: string }[];
}

const { title, description, current, nav, section, breadcrumb } = Astro.props;
const hasNav = nav && nav.length > 0;

let prev: NavItem | undefined;
let next: NavItem | undefined;
if (hasNav && current) {
  const idx = nav.findIndex((item) => item.href === current);
  if (idx > 0) {
    prev = nav[idx - 1];
    if (idx < nav.length - 1) next = nav[idx + 1];
  }
}
---

<Layout title={title} description={description}>
  <div class="docs-shell">
    <Header section={section} sectionNav={nav} current={current} />

    <div class:list={["docs-body", { "no-sidebar": !hasNav }]}>
      {hasNav && (
        <aside class="sidebar" id="sidebar">
          <nav>
            {nav.map((item) => (
              <a
                href={item.href}
                class:list={["nav-link", { active: current === item.href, indent: item.indent }]}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </aside>
      )}

      <main class="content">
        {breadcrumb && breadcrumb.length > 0 && (
          <nav class="breadcrumb" aria-label="Breadcrumb">
            {breadcrumb.map((item, i) => (
              <>
                {i > 0 && <span class="breadcrumb-sep">/</span>}
                {i < breadcrumb.length - 1 ? (
                  <a href={item.href} class="breadcrumb-link">{item.label}</a>
                ) : (
                  <span class="breadcrumb-current">{item.label}</span>
                )}
              </>
            ))}
          </nav>
        )}

        <article class="prose">
          <slot />
        </article>

        {(prev || next) && (
          <nav class="prev-next" aria-label="Pagination">
            {prev && (
              <a href={prev.href} class="prev-next-link prev">
                <span class="prev-next-label">Previous</span>
                <span class="prev-next-title">{prev.label}</span>
              </a>
            )}
            {next && (
              <a href={next.href} class="prev-next-link next">
                <span class="prev-next-label">Next</span>
                <span class="prev-next-title">{next.label}</span>
              </a>
            )}
          </nav>
        )}
      </main>
    </div>

    <Footer />
  </div>

</Layout>

<style>
  .docs-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .docs-body {
    display: flex;
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .docs-body.no-sidebar {
    justify-content: center;
  }

  .sidebar {
    width: 260px;
    flex-shrink: 0;
    padding: 32px 24px;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    overflow-y: auto;
  }

  .sidebar nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-link {
    display: block;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link.indent {
    padding-left: 28px;
    font-size: 0.85rem;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--nav-hover-bg);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--blue);
    background: rgba(91, 140, 254, 0.1);
    font-weight: 500;
  }

  .content {
    flex: 1;
    min-width: 0;
    padding: 48px 48px 80px;
  }

  .no-sidebar .content {
    max-width: 800px;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 0.85rem;
  }

  .breadcrumb-link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .breadcrumb-sep {
    color: var(--border);
  }

  .breadcrumb-current {
    color: var(--text);
    font-weight: 500;
  }

  /* Prev / Next */
  .prev-next {
    display: flex;
    gap: 16px;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  .prev-next-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    width: 50%;
  }

  .prev-next-link:hover {
    border-color: var(--blue);
    background: rgba(91, 140, 254, 0.04);
    text-decoration: none;
  }

  .prev-next-link.next {
    text-align: right;
    margin-left: auto;
  }

  .prev-next-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .prev-next-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--blue);
  }

  .prose {
    max-width: 800px;
  }

  .prose :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .prose :global(.lead) {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    margin-top: 48px;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .prose :global(p) {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(ul),
  .prose :global(ol) {
    color: var(--text-muted);
    margin-bottom: 16px;
    padding-left: 24px;
    line-height: 1.7;
  }

  .prose :global(li) {
    margin-bottom: 6px;
  }

  .prose :global(li code),
  .prose :global(p code),
  .prose :global(td code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--text);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    text-align: left;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose :global(td) {
    padding: 10px 16px;
    border-bottom: 1px solid var(--table-border);
    color: var(--text-muted);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }

    .content {
      padding: 32px 24px 64px;
    }

    .prev-next-link {
      padding: 12px 16px;
    }
  }
</style>
