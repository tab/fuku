---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description: string;
  current: string;
}

const { title, description, current } = Astro.props;
const base = import.meta.env.BASE_URL;

const nav = [
  { label: "Getting Started", href: `${base}docs/getting-started/` },
  { label: "Configuration", href: `${base}docs/configuration/` },
  { label: "CLI Commands", href: `${base}docs/cli/` },
  { label: "Features", href: `${base}docs/features/` },
  { label: "Privacy", href: `${base}docs/privacy/` },
];
---

<Layout title={title} description={description}>
  <div class="docs-shell">
    <Header label="Docs">
      <button class="menu-toggle" aria-label="Toggle navigation" aria-controls="sidebar" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </Header>

    <div class="docs-body">
      <aside class="sidebar" id="sidebar">
        <nav>
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={["nav-link", { active: current === item.href }]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <main class="content">
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>
  </div>

  <script>
    const toggle = document.querySelector('.menu-toggle');
    const sidebar = document.getElementById('sidebar');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('open');
        const expanded = sidebar.classList.contains('open');
        toggle.setAttribute('aria-expanded', String(expanded));
      });
    }
  </script>
</Layout>

<style>
  .docs-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
  }

  .docs-body {
    display: flex;
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .sidebar {
    width: 260px;
    flex-shrink: 0;
    padding: 32px 24px;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    overflow-y: auto;
  }

  .sidebar nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-link {
    display: block;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--blue);
    background: rgba(91, 140, 254, 0.1);
    font-weight: 500;
  }

  .content {
    flex: 1;
    min-width: 0;
    padding: 48px 48px 80px;
  }

  .prose {
    max-width: 800px;
  }

  .prose :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .prose :global(.lead) {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 48px;
    line-height: 1.7;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    margin-top: 48px;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .prose :global(p) {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .prose :global(ul),
  .prose :global(ol) {
    color: var(--text-muted);
    margin-bottom: 16px;
    padding-left: 24px;
    line-height: 1.7;
  }

  .prose :global(li) {
    margin-bottom: 6px;
  }

  .prose :global(li code),
  .prose :global(p code),
  .prose :global(td code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--text);
  }

  .prose :global(.code-block) {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 20px 24px;
    overflow-x: auto;
    margin-bottom: 24px;
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--glass-glow);
  }

  .prose :global(.code-block)::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    padding: 1px;
    background: linear-gradient(
      180deg,
      var(--glass-shine) 0%,
      transparent 50%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .prose :global(.code-block pre) {
    margin: 0;
  }

  .prose :global(.code-block code) {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    text-align: left;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose :global(td) {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }

    .sidebar {
      display: none;
      position: fixed;
      top: 56px;
      left: 0;
      right: 0;
      width: 100%;
      height: auto;
      max-height: calc(100vh - 56px);
      border-right: none;
      border-bottom: 1px solid var(--border);
      background: rgba(10, 10, 15, 0.95);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      z-index: 99;
      padding: 16px 24px;
    }

    .sidebar.open {
      display: block;
    }

    .content {
      padding: 32px 24px 64px;
    }
  }
</style>
