---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container">
    <div class="links">
      <a href={`${base}docs/getting-started/`}>
        Docs
      </a>
      <span class="sep">&middot;</span>
      <a href="https://github.com/tab/fuku" target="_blank" rel="noopener">
        GitHub
      </a>
      <span class="sep">&middot;</span>
      <a
        href="https://github.com/tab/fuku/releases"
        target="_blank"
        rel="noopener"
      >
        Releases
      </a>
      <span class="sep">&middot;</span>
      <a
        href="https://github.com/tab/fuku/blob/master/LICENSE"
        target="_blank"
        rel="noopener"
      >
        MIT License
      </a>
    </div>
    <p class="made">Made in Estonia</p>
  </div>
</footer>

<style>
  .footer {
    padding: 40px 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .links {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .links a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .links a:hover {
    color: var(--text);
  }

  .sep {
    color: var(--border);
  }

  .made {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
