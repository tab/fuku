---
import CodeTerminal from "./CodeTerminal.astro";
---

<section class="install" id="install">
  <div class="container">
    <h2 class="section-title">Install</h2>

    <div class="homebrew">
      <h3>Homebrew</h3>
      <CodeTerminal code={`brew install tab/apps/fuku`} />
    </div>

    <div class="source">
      <h3>Build from source</h3>
      <CodeTerminal code={`git clone https://github.com/tab/fuku.git
cd fuku
go build -o cmd/fuku cmd/main.go
sudo ln -sf $(pwd)/cmd/fuku /usr/local/bin/fuku`} />
    </div>

  </div>
</section>

<style>
  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 48px;
  }

  .homebrew {
    max-width: 600px;
    margin: 0 auto 48px;
  }

  .source {
    max-width: 600px;
    margin: 0 auto 48px;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 16px;
    text-align: center;
  }
</style>
