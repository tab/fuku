---
import CodeTerminal from "./CodeTerminal.astro";
import { getInstallMethods } from "../data/install";

const methods = getInstallMethods();
---

<section class="install" id="install">
  <div class="container">
    <h2 class="section-title">Install</h2>

    {methods.map((method) => (
      <div class="method">
        <h3>{method.title}</h3>
        <CodeTerminal code={method.code} />
      </div>
    ))}

  </div>
</section>

<style>
  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 48px;
  }

  .method {
    max-width: 600px;
    margin: 0 auto 48px;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 16px;
    text-align: center;
  }
</style>
