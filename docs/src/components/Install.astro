---
import CodeTerminal from "./CodeTerminal.astro";
import { getInstallMethods } from "../data/install";

const methods = getInstallMethods();
---

<section class="install-section" id="install">
  <div class="install-inner">
    <h2 class="section-title">Install</h2>

    {methods.map((method) => (
      <div class="method">
        <h3>{method.title}</h3>
        <CodeTerminal code={method.code} />
      </div>
    ))}
  </div>
</section>

<style>
  .install-section {
    border-top: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .install-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 100px 56px;
  }

  .section-title {
    font-family: var(--heading);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    text-align: center;
    margin-bottom: 48px;
  }

  .method {
    max-width: 600px;
    margin: 0 auto 48px;
  }

  h3 {
    font-family: var(--heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 16px;
    text-align: center;
  }
</style>
