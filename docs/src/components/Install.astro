---

---

<section class="install" id="install">
  <div class="container">
    <h2 class="section-title">Install</h2>

    <div class="homebrew">
      <h3>Homebrew</h3>
      <div class="code-block">
        <pre><code>brew install tab/apps/fuku</code></pre>
      </div>
    </div>

    <div class="source">
      <h3>Build from source</h3>
      <div class="code-block">
        <pre><code>git clone https://github.com/tab/fuku.git
cd fuku
go build -o cmd/fuku cmd/main.go
sudo ln -sf $(pwd)/cmd/fuku /usr/local/bin/fuku</code></pre>
      </div>
    </div>

  </div>
</section>

<style>
  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 48px;
  }

  .homebrew {
    max-width: 600px;
    margin: 0 auto 48px;
  }

  .source {
    max-width: 600px;
    margin: 0 auto 48px;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 16px;
    text-align: center;
  }

  .code-block {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    padding: 20px 24px;
    overflow-x: auto;
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--glass-glow);
  }

  .code-block::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius);
    padding: 1px;
    background: linear-gradient(
      180deg,
      var(--glass-shine) 0%,
      transparent 50%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  pre {
    margin: 0;
  }

  code {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

</style>
