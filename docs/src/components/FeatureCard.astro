---
import type { Feature } from "../data/features";

interface Props {
  feature: Feature;
  showIcon?: boolean;
}

const { feature: f, showIcon = false } = Astro.props;
---

<a href={f.href} class="card">
  {showIcon && (
    <div class="icon">
      {f.icon === "terminal" && (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 17 10 11 4 5" />
          <line x1="12" y1="19" x2="20" y2="19" />
        </svg>
      )}
      {f.icon === "layers" && (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 2 7 12 12 22 7 12 2" />
          <polyline points="2 17 12 22 22 17" />
          <polyline points="2 12 12 17 22 12" />
        </svg>
      )}
      {f.icon === "check" && (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
          <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
      )}
      {f.icon === "refresh" && (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 4 23 10 17 10" />
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
        </svg>
      )}
      {f.icon === "scroll" && (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
      )}
      {f.icon === "shield" && (
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          <polyline points="9 12 12 15 16 10" />
        </svg>
      )}
    </div>
  )}
  <h3>{f.title}</h3>
  <p>{f.description}</p>
  <span class="arrow">Learn more</span>
</a>

<style>
  .card {
    position: relative;
    display: block;
    background: var(--glass-card-bg);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid var(--glass-card-border);
    border-radius: 20px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.35s ease;
  }

  .card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    border-radius: 20px 20px 0 0;
    background: linear-gradient(
      180deg,
      var(--glass-card-shine) 0%,
      transparent 100%
    );
    pointer-events: none;
  }

  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 1px;
    background: linear-gradient(
      180deg,
      var(--glass-card-ring-top) 0%,
      transparent 40%,
      transparent 60%,
      var(--glass-card-ring-bottom) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .card:hover {
    transform: translateY(-4px) scale(1.01);
    border-color: var(--glass-card-hover-border);
    box-shadow: var(--glass-card-shadow);
    text-decoration: none;
  }

  .icon {
    position: relative;
    color: var(--blue);
    margin-bottom: 16px;
  }

  h3 {
    position: relative;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text);
  }

  p {
    position: relative;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .arrow {
    position: relative;
    font-size: 0.85rem;
    color: var(--blue);
    font-weight: 500;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .card:hover .arrow {
    opacity: 1;
  }
</style>
