---
import type { Feature } from "../data/features";

interface Props {
  feature: Feature;
  showIcon?: boolean;
}

const { feature: f } = Astro.props;
---

<a href={f.href} class="card">
  <h3>{f.title}</h3>
  <p>{f.description}</p>
  <span class="arrow">Learn more &rarr;</span>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px;
    border-radius: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }

  .card:hover {
    border-color: var(--text-muted);
    transform: translateY(-2px);
    text-decoration: none;
  }

  h3 {
    font-family: var(--heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--text);
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
  }

  .arrow {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blue);
    margin-top: auto;
    padding-top: 8px;
  }
</style>
