---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1 class="title">
        All services<br />
        <span class="title-accent">one terminal</span>
      </h1>
      <p class="description">
        Lightweight CLI tool for running and managing multiple local services.
        Tier-based startup ordering, interactive TUI, hot-reload, and readiness
        checks – all from a single YAML config.
      </p>
      <div class="actions">
        <a href={`${base}docs/getting-started/`} class="btn btn-primary">Get Started <span class="arrow">&rarr;</span></a>
        <a
          href="https://github.com/tab/fuku"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost"
        >
          GitHub
        </a>
      </div>
      <div class="install-hint">
        <span class="dollar">$</span>
        <span class="install-cmd">brew install tab/apps/fuku</span>
      </div>
    </div>
    <div class="hero-visual">
      <slot />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 72px 56px;
    max-width: 1320px;
    margin: 0 auto;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 3fr 7fr;
    gap: 64px;
    align-items: center;
  }

  .hero-visual {
    display: flex;
    justify-content: flex-end;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blue);
    padding: 6px 12px;
    border: 1px solid color-mix(in srgb, var(--blue) 25%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--blue) 6%, transparent);
    margin-bottom: 24px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background: var(--blue);
  }

  .title {
    font-family: var(--heading);
    font-weight: 600;
    font-size: 3rem;
    line-height: 1.0;
    letter-spacing: -0.045em;
    margin: 0 0 20px;
    color: var(--text);
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .title-accent {
    font-family: var(--mono);
    font-weight: 500;
    color: var(--blue);
  }

  .description {
    font-size: 1.2rem;
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  .actions {
    display: flex;
    gap: 12px;
    margin-top: 36px;
    flex-wrap: wrap;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .install-hint {
    margin-top: 24px;
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 14px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .install-cmd {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text);
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.15s, opacity 0.15s;
  }

  .btn:hover {
    transform: translateY(-1px);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--text);
    color: var(--bg);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-ghost:hover {
    border-color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-visual {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 48px 24px;
    }

    .title {
      font-size: 2.25rem;
    }

    .description {
      font-size: 1.05rem;
    }
  }
</style>
