---
import ThemeToggle from "./ThemeToggle.astro";
import type { NavItem } from "../data/nav";

interface Props {
  section?: "features" | "docs" | "plugins" | "about" | "why";
  sectionNav?: NavItem[];
  current?: string;
  wide?: boolean;
}

const { section, sectionNav, current, wide } = Astro.props;
const base = import.meta.env.BASE_URL;

const mainLinks = [
  { label: "Home", href: `${base}`, key: undefined as string | undefined },
  { label: "Why", href: `${base}why/`, key: "why" },
  { label: "Features", href: `${base}features/`, key: "features" },
  { label: "Docs", href: `${base}docs/`, key: "docs" },
  { label: "Plugins", href: `${base}plugins/`, key: "plugins" },
  { label: "About", href: `${base}about/`, key: "about" },
];
---

<header class="topbar">
  <input type="checkbox" id="mobile-toggle" class="mobile-toggle" aria-label="Toggle menu" />

  <div class:list={["topbar-inner", { wide }]}>
    <div class="topbar-left">
      <a href={`${base}`} class="logo">
        <span class="brand-name">fuku</span>
        <span class="brand-version">v0.19.1</span>
      </a>

      <nav class="topbar-nav">
        <a href={`${base}why/`} class:list={["nav-link", { active: section === "why" }]}>Why</a>
        <a href={`${base}features/`} class:list={["nav-link", { active: section === "features" }]}>Features</a>
        <a href={`${base}docs/`} class:list={["nav-link", { active: section === "docs" }]}>Docs</a>
        <a href={`${base}plugins/`} class:list={["nav-link", { active: section === "plugins" }]}>Plugins</a>
        <a href={`${base}about/`} class:list={["nav-link", { active: section === "about" }]}>About</a>
      </nav>
    </div>
    <div class="topbar-right">
      <ThemeToggle />
      <a
        href="https://github.com/tab/fuku"
        target="_blank"
        rel="noopener"
        class="github-cta"
      >GitHub
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
      </a>
      <label for="mobile-toggle" class="mobile-menu-btn">
        <svg class="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </label>
    </div>
  </div>

  <div class="mobile-menu">
    <nav>
      {mainLinks.map((link) => (
        <>
          <a
            href={link.href}
            class:list={["mobile-link", { active: section === link.key }]}
          >
            {link.label}
          </a>
          {link.key === section && sectionNav && sectionNav.map((item) => (
            <a
              href={item.href}
              class:list={["mobile-link nested", { active: current === item.href }]}
            >
              {item.label}
            </a>
          ))}
        </>
      ))}
    </nav>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--header-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .topbar-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .topbar-inner.wide {
    max-width: none;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .logo:hover {
    text-decoration: none;
  }

  .brand-version {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 8px;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--text);
    font-weight: 600;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .github-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 8px;
    background: var(--text);
    color: var(--bg);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .github-cta:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  /* Hidden checkbox drives the menu */
  .mobile-toggle {
    display: none;
  }

  .mobile-menu-btn {
    display: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px;
  }

  .icon-close {
    display: none;
  }

  .mobile-toggle:checked ~ .topbar-inner .mobile-menu-btn .icon-menu {
    display: none;
  }

  .mobile-toggle:checked ~ .topbar-inner .mobile-menu-btn .icon-close {
    display: block;
  }

  .mobile-menu {
    display: none;
    overflow: hidden;
    border-top: 1px solid var(--border);
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    padding: 12px 24px;
    gap: 2px;
  }

  .mobile-link {
    display: block;
    padding: 10px 12px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
  }

  .mobile-link:hover {
    color: var(--text);
    background: var(--nav-hover-bg);
    text-decoration: none;
  }

  .mobile-link.active {
    color: var(--text);
  }

  .mobile-link.nested {
    padding-left: 28px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .mobile-link.nested.active {
    color: var(--blue);
  }

  @media (max-width: 768px) {
    .topbar-inner {
      padding: 0 24px;
    }

    .topbar-nav {
      display: none;
    }

    .github-cta {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .mobile-toggle:checked ~ .mobile-menu {
      display: block;
      animation: slideDown 0.25s ease-out;
    }
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
