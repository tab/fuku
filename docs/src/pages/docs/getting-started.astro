---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeEditor from "../../components/CodeEditor.astro";
import CodeTerminal from "../../components/CodeTerminal.astro";
import { getDocsNav } from "../../data/nav";

const base = import.meta.env.BASE_URL;
const current = `${base}docs/getting-started/`;
const nav = getDocsNav(base);
---

<DocsLayout
  title="Getting Started - fuku"
  description="Install fuku and get your services running in minutes."
  current={current}
  nav={nav}
  section="docs"
  breadcrumb={[{ label: "Docs", href: `${base}docs/` }, { label: "Getting Started", href: current }]}
>
  <h1>Getting Started</h1>
  <p class="lead">Install fuku and get your services running in minutes.</p>

  <h2>Installation</h2>

  <h3>Homebrew</h3>
  <CodeTerminal code={`brew install tab/apps/fuku`} />

  <h3>Install Script</h3>
  <CodeTerminal code={`curl -fsSL https://getfuku.sh/install.sh | sh`} />

  <h3>Build from Source</h3>
  <CodeTerminal code={`git clone https://github.com/tab/fuku.git
cd fuku
go build -o cmd/fuku cmd/main.go
sudo ln -sf $(pwd)/cmd/fuku /usr/local/bin/fuku`} />

  <hr />

  <h2>Quick Start</h2>

  <ol>
    <li><strong>Generate a config file</strong> in your project root:</li>
  </ol>
  <CodeTerminal code={`fuku init`} />

  <ol start="2">
    <li><strong>Edit <code>fuku.yaml</code></strong> to define your services, tiers, and profiles. See the <a href={`${base}docs/configuration/`}>Configuration</a> page for the full reference.</li>
  </ol>

  <ol start="3">
    <li><strong>Run your services:</strong></li>
  </ol>
  <CodeTerminal code={`# Run with the default profile (interactive TUI)
fuku

# Run a specific profile
fuku run core

# Run without TUI
fuku run core --no-ui`} />

  <hr />

  <h2>Service Requirements</h2>

  <p>
    By default, fuku executes <code>make run</code> inside each service's directory. You can override this with a custom <code>command</code>:
  </p>

  <CodeEditor title="fuku.yaml" lang="yaml" code={`services:
  api:
    dir: ./api
    command: go run cmd/main.go    # Custom command (runs via sh -c)
  worker:
    dir: ./worker
    # No command — uses "make run" (requires Makefile)`} />

  <p>
    When using the default <code>make run</code>, each service directory must contain a <code>Makefile</code> with a <code>run</code> target:
  </p>

  <CodeEditor title="Makefile" lang="makefile" code={`run:
	npm start`} />

  <p>
    If a <code>.env.development</code> file exists in the service directory, fuku automatically detects it and passes it via the <code>ENV_FILE</code> variable.
  </p>

  <p>
    Check the <a href={`${base}docs/examples/`}>Examples</a> page for real-world configuration patterns.
  </p>
</DocsLayout>
