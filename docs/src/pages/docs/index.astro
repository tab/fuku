---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocsNav } from "../../data/nav";

const base = import.meta.env.BASE_URL;
const current = `${base}docs/`;
const nav = getDocsNav(base);

const cards = [
  { href: `${base}docs/getting-started/`, num: "01", title: "Getting Started", desc: "Install fuku and get your services running in minutes." },
  { href: `${base}docs/configuration/`, num: "02", title: "Configuration", desc: "Complete reference for fuku.yaml – services, tiers, profiles, and more." },
  { href: `${base}docs/cli/`, num: "03", title: "CLI Commands", desc: "All available commands, flags, and short aliases." },
  { href: `${base}docs/api/`, num: "04", title: "REST API", desc: "Observe and control services from IDE plugins, desktop apps, and CLI tools." },
  { href: `${base}docs/examples/`, num: "05", title: "Examples", desc: "Real-world configuration patterns for common project setups." },
  { href: `${base}docs/troubleshooting/`, num: "06", title: "Troubleshooting", desc: "Common issues and how to resolve them." },
  { href: `${base}docs/privacy/`, num: "07", title: "Privacy", desc: "What fuku collects and how to opt out." },
];
---

<DocsLayout
  title="Documentation - fuku"
  description="Learn how to install, configure, and use fuku."
  current={current}
  nav={nav}
  section="docs"
>
  <h1>Documentation</h1>
  <p class="lead">Learn how to install, configure, and use fuku.</p>

  <div class="doc-grid">
    {cards.map((c) => (
      <a href={c.href} class="doc-card">
        <div class="card-num">{c.num}</div>
        <h3>{c.title}</h3>
        <p>{c.desc}</p>
        <span class="card-link">Read &rarr;</span>
      </a>
    ))}
  </div>
</DocsLayout>

<style>
  .doc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 32px;
  }

  .doc-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px;
    border-radius: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }

  .doc-card:hover {
    border-color: var(--text-muted);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .card-num {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--blue);
    letter-spacing: 0.15em;
  }

  .doc-card h3 {
    font-family: var(--heading);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--text);
  }

  .doc-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  .card-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blue);
    margin-top: auto;
    padding-top: 8px;
  }

  @media (max-width: 900px) {
    .doc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .doc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
