---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeTerminal from "../../components/CodeTerminal.astro";
import KeyboardControls from "../../components/KeyboardControls.astro";
import { getDocsNav } from "../../data/nav";

const base = import.meta.env.BASE_URL;
const current = `${base}docs/cli/`;
const nav = getDocsNav(base);
---

<DocsLayout
  title="CLI Commands - fuku"
  description="Command reference for the fuku CLI."
  current={current}
  nav={nav}
  section="docs"
  breadcrumb={[{ label: "Docs", href: `${base}docs/` }, { label: "CLI Commands", href: current }]}
>
  <h1>CLI Commands</h1>
  <p class="lead">Command reference, flags, TUI controls, and environment file loading.</p>

  <h2>Commands</h2>

  <table>
    <thead>
      <tr>
        <th>Command</th>
        <th>Alias</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>fuku run [profile]</code></td>
        <td><code>r</code></td>
        <td>Run services for a profile (default if omitted)</td>
      </tr>
      <tr>
        <td><code>fuku stop [profile]</code></td>
        <td><code>s</code></td>
        <td>Stop services by killing processes in service directories</td>
      </tr>
      <tr>
        <td><code>fuku logs [services...]</code></td>
        <td><code>l</code></td>
        <td>Stream logs from a running fuku instance</td>
      </tr>
      <tr>
        <td><code>fuku init</code></td>
        <td><code>i</code></td>
        <td>Generate a <code>fuku.yaml</code> template</td>
      </tr>
      <tr>
        <td><code>fuku version</code></td>
        <td><code>-v</code>, <code>--version</code></td>
        <td>Show version</td>
      </tr>
      <tr>
        <td><code>fuku help</code></td>
        <td><code>-h</code>, <code>--help</code></td>
        <td>Show help</td>
      </tr>
    </tbody>
  </table>

  <hr />

  <h2>Flags</h2>

  <table>
    <thead>
      <tr>
        <th>Flag</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>--config</code>, <code>-c</code></td>
        <td>Path to config file (default: <code>fuku.yaml</code>, falls back to <code>fuku.yml</code>). Disables automatic override file merging. Only supported with <code>run</code>, <code>stop</code>, and <code>logs</code> commands</td>
      </tr>
      <tr>
        <td><code>--no-ui</code></td>
        <td>Run without the interactive TUI (log-only mode)</td>
      </tr>
      <tr>
        <td><code>--profile</code></td>
        <td>Filter by profile (used with <code>logs</code> command)</td>
      </tr>
    </tbody>
  </table>

  <p>Flags can be placed in any position:</p>
  <CodeTerminal code={`fuku run core --no-ui
fuku --no-ui run core        # Same result`} />

  <hr />

  <h2>Usage Examples</h2>

  <CodeTerminal code={`# Run with TUI (default profile)
fuku

# Run a specific profile without TUI
fuku run core --no-ui

# Use short aliases
fuku r core

# Stop services for a profile
fuku stop                       # Default profile
fuku stop core                  # Specific profile

# Stream logs from running instance (separate terminal)
fuku logs                       # All services
fuku logs api auth              # Specific services
fuku logs --profile core api    # Filter by profile
fuku l api db                   # Short alias

# Use a custom config file
fuku --config path/to/fuku.yaml run core
fuku -c custom.yaml run core

# Generate config template
fuku init

# Show help / version
fuku help
fuku version`} />

  <hr />

  <h2>TUI Controls</h2>

  <p>When running with the interactive TUI (default), use these keyboard shortcuts:</p>

  <KeyboardControls />

  <hr />

  <h2>Environment File Loading</h2>

  <p>fuku automatically loads environment files using <a href="https://github.com/joho/godotenv" target="_blank" rel="noopener">godotenv</a>, in this order (later files take precedence):</p>

  <ol>
    <li><code>.env</code></li>
    <li><code>.env.&lt;GO_ENV&gt;</code></li>
    <li><code>.env.&lt;GO_ENV&gt;.local</code></li>
  </ol>

  <p>
    If a service directory contains a <code>.env.development</code> file, it is automatically detected and passed to the service via the <code>ENV_FILE</code> variable.
  </p>
</DocsLayout>
