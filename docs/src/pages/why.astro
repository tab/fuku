---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Why fuku - fuku"
  description="When to use fuku, how it compares to Docker Compose, Foreman, and Overmind, and why it exists."
>
  <Header section="why" />

  <main>
    <!-- ─── Hero ─── -->
    <section class="hero">
      <div class="inner">
        <div class="hero-eyebrow">// local development orchestrator</div>
        <h1 class="hero-title">
          Why <span class="hero-accent">fuku</span>
        </h1>
        <p class="hero-desc">
          Run all your services as native processes with proper startup ordering,
          readiness checks, and a live dashboard. No Docker required.
        </p>
      </div>
    </section>

    <!-- ─── Stats ─── -->
    <section class="stats-section">
      <div class="inner">
        <div class="stats-grid reveal">
          <div class="stat-cell">
            <span class="stat-big" data-count="30" data-suffix="×">0×</span>
            <span class="stat-label">less memory than Compose</span>
            <span class="stat-detail">~60 MB vs ~2 GB for 50 services</span>
          </div>
          <div class="stat-cell">
            <span class="stat-big" data-count="0">0</span>
            <span class="stat-label">Docker dependencies</span>
            <span class="stat-detail">Native processes, no VM, no daemon</span>
          </div>
          <div class="stat-cell">
            <span class="stat-big" data-count="1">1</span>
            <span class="stat-label">command to start everything</span>
            <span class="stat-detail">Tier-based ordering with readiness checks</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Memory visual ─── -->
    <section class="mem-section">
      <div class="inner">
        <div class="section-label">// resource usage</div>
        <h2 class="section-h2">Memory comparison</h2>
        <p class="section-sub">50 services, same workload, four runtimes. fuku runs them as native processes.</p>

        <div class="mem-toggles" id="mem-toggles">
          <button class="mem-toggle active" data-runtime="go"><span class="mem-toggle-swatch go"></span>Go<span class="mem-toggle-count">50 services</span></button>
          <button class="mem-toggle" data-runtime="node"><span class="mem-toggle-swatch node"></span>Node.js<span class="mem-toggle-count">50 services</span></button>
          <button class="mem-toggle" data-runtime="python"><span class="mem-toggle-swatch python"></span>Python<span class="mem-toggle-count">50 services</span></button>
          <button class="mem-toggle" data-runtime="ruby"><span class="mem-toggle-swatch ruby"></span>Ruby<span class="mem-toggle-count">50 services</span></button>
        </div>

        <div class="mem-bars" id="mem-visual">
          <div class="mem-row">
            <div class="mem-label">
              <span class="mem-tool">Docker Compose</span>
              <span class="mem-val-info"><span class="mem-val" id="mem-compose-val">~2 GB containers</span><span class="mem-val-dim" id="mem-compose-note">+ ~2 GB Docker Desktop VM</span></span>
            </div>
            <div class="mem-track">
              <div class="mem-bar bar-compose-vm" id="mem-compose-vm" style="width: 0;" data-target-width="25%"><span class="bar-label">Docker Desktop VM</span></div>
              <div class="mem-bar bar-compose-containers" id="mem-compose-bar" style="width: 0;" data-target-width="24.4%"><span class="bar-label">containers</span></div>
            </div>
          </div>
          <div class="mem-row">
            <div class="mem-label">
              <span class="mem-tool">fuku <span class="mem-runtime-badge" id="mem-runtime-badge">Go</span></span>
              <span class="mem-val-info"><span class="mem-val" id="mem-fuku-val">~60 MB total</span><span class="mem-val-dim" id="mem-fuku-note">No VM, no container runtime</span></span>
            </div>
            <div class="mem-track" id="mem-fuku-track">
              <div style="height: 100%; background: #00ADD8; width: 0; transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);" data-target-width="0.6%"></div>
            </div>
          </div>
        </div>

        <div class="mem-axis">
          <span>0 MB</span><span>2 GB</span><span>4 GB</span><span>6 GB</span><span>8 GB</span>
        </div>
      </div>
    </section>

    <!-- ─── When to use ─── -->
    <section class="when-section">
      <div class="inner">
        <div class="section-label">// use cases</div>
        <h2 class="section-h2">When to use fuku</h2>

        <div class="when-grid">
          <div class="when-card when-simple reveal-left">
            <div class="when-kicker">Keep it simple</div>
            <h3>A backend and a frontend.</h3>
            <p>Two terminal tabs. Done.</p>
            <span class="when-pill">You don't need fuku.</span>
          </div>
          <div class="when-card when-complex reveal-right">
            <div class="when-kicker accent">Complex configuration</div>
            <h3>You want fuku.</h3>
            <ul class="when-list">
              <li><span class="check">&#10003;</span>Multiple backend services with dependencies</li>
              <li><span class="check">&#10003;</span>BFF layer between APIs and the UI</li>
              <li><span class="check">&#10003;</span>Several frontends – SPA, docs, Swagger</li>
              <li><span class="check">&#10003;</span>Gateways, mock servers, infrastructure</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Tradeoffs ─── -->
    <section class="vs-section">
      <div class="inner">
        <div class="section-label">// docker compose vs fuku</div>
        <h2 class="section-h2">Local development tradeoffs</h2>
        <p class="section-sub">Compose runs containers. fuku runs native processes. Here's what that means day to day.</p>

        <div class="vs-table reveal">
          <div class="vs-header">
            <span>Docker Compose</span>
            <span class="vs-header-accent">fuku</span>
          </div>
          <div class="vs-row">
            <div class="vs-cell">
              <h4>~2 GB+ container memory</h4>
              <p>Plus 2–4 GB for the Docker Desktop VM on macOS</p>
            </div>
            <div class="vs-cell vs-cell-accent">
              <h4>~60 MB total</h4>
              <p>Native processes. No VM, no daemon, no overhead.</p>
            </div>
          </div>
          <div class="vs-row">
            <div class="vs-cell">
              <h4>Minutes to start</h4>
              <p>Image pulls, layer extraction, network setup, cgroup init</p>
            </div>
            <div class="vs-cell vs-cell-accent">
              <h4>Seconds to start</h4>
              <p>Native fork and exec. No container initialization.</p>
            </div>
          </div>
          <div class="vs-row">
            <div class="vs-cell">
              <h4>Broken file watching</h4>
              <p>macOS VM proxies FS events. Latency. Missed changes.</p>
            </div>
            <div class="vs-cell vs-cell-accent">
              <h4>Instant hot-reload</h4>
              <p>Native fsnotify. Debounced. Configurable per-service.</p>
            </div>
          </div>
          <div class="vs-row">
            <div class="vs-cell">
              <h4>depends_on ≠ ready</h4>
              <p>Container started doesn't mean service is accepting requests</p>
            </div>
            <div class="vs-cell vs-cell-accent">
              <h4>Real readiness gates</h4>
              <p>HTTP, TCP, and log pattern checks. Tier-based startup.</p>
            </div>
          </div>
          <div class="vs-row vs-row-last">
            <div class="vs-cell">
              <h4>Interleaved log noise</h4>
              <p>No overview. No controls. grep your way through stdout.</p>
            </div>
            <div class="vs-cell vs-cell-accent">
              <h4>Live TUI dashboard</h4>
              <p>Per-service status, CPU/memory, restart controls, log filtering.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Comparison table ─── -->
    <section class="matrix-section">
      <div class="inner">
        <div class="section-label">// comparison</div>
        <h2 class="section-h2">Feature matrix</h2>

        <div class="matrix reveal">
          <div class="mx-head">
            <span></span>
            <span>Foreman</span>
            <span>Overmind</span>
            <span>Compose</span>
            <span class="mx-accent">fuku</span>
          </div>
          <div class="mx-row"><span class="mx-feat">Native processes</span><span class="mx-y">&#10003;</span><span class="mx-y">&#10003;</span><span class="mx-label">Containers</span><span class="mx-y mx-accent-y">&#10003;</span></div>
          <div class="mx-row mx-alt"><span class="mx-feat">Startup ordering</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-label">depends_on</span><span class="mx-label accent">Tier-based</span></div>
          <div class="mx-row"><span class="mx-feat">Readiness checks</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-label">Extra config</span><span class="mx-label accent">HTTP, TCP, log</span></div>
          <div class="mx-row mx-alt"><span class="mx-feat">Interactive TUI</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-y mx-accent-y">&#10003;</span></div>
          <div class="mx-row"><span class="mx-feat">CPU/memory monitoring</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-label">docker stats</span><span class="mx-label accent">Built-in</span></div>
          <div class="mx-row mx-alt"><span class="mx-feat">Hot-reload</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-label">Volume mounts</span><span class="mx-label accent">Built-in</span></div>
          <div class="mx-row"><span class="mx-feat">Service profiles</span><span class="mx-n">&mdash;</span><span class="mx-n">&mdash;</span><span class="mx-y">&#10003;</span><span class="mx-y mx-accent-y">&#10003;</span></div>
          <div class="mx-row mx-alt"><span class="mx-feat">Per-process terminal</span><span class="mx-n">&mdash;</span><span class="mx-label">tmux</span><span class="mx-label">docker exec</span><span class="mx-y mx-accent-y">&#10003;</span></div>
          <div class="mx-row"><span class="mx-feat">Log streaming</span><span class="mx-label">stdout</span><span class="mx-label">stdout</span><span class="mx-label">docker logs</span><span class="mx-label accent">Socket-based</span></div>
          <div class="mx-row mx-alt"><span class="mx-feat">Config format</span><span class="mx-label">Procfile</span><span class="mx-label">Procfile</span><span class="mx-label">YAML</span><span class="mx-label accent">YAML</span></div>
          <div class="mx-row"><span class="mx-feat">Requires Docker</span><span class="mx-label">No</span><span class="mx-label">No</span><span class="mx-label">Required</span><span class="mx-label accent">No</span></div>
          <div class="mx-foot">
            <span>Memory (~50 services)</span>
            <span>~60 MB</span>
            <span>~60 MB</span>
            <span class="mx-bad">~2 GB+</span>
            <span class="mx-good">~60 MB</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CTA ─── -->
    <section class="cta-section">
      <div class="inner">
        <div class="cta-card reveal">
          <div class="cta-text">
            <div class="cta-eyebrow">// try it out</div>
            <h2 class="cta-title">Add a fuku.yaml. List your services. Run fuku.</h2>
          </div>
          <div class="cta-actions">
            <a href={`${base}docs/getting-started/`} class="cta-btn-primary">Getting started &rarr;</a>
            <a href={`${base}docs/configuration/`} class="cta-btn-ghost">Configuration</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Layout ── */
  .inner { max-width: 1180px; margin: 0 auto; padding: 0 56px; }

  .section-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 14px;
  }

  .section-h2 {
    font-family: var(--heading);
    font-size: 2.75rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 12px;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 0 48px;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Scroll reveals ── */
  .reveal, .reveal-left, .reveal-right {
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal { transform: translateY(24px); }
  .reveal-left { transform: translateX(-32px); }
  .reveal-right { transform: translateX(32px); }

  .reveal.visible, .reveal-left.visible, .reveal-right.visible {
    opacity: 1;
    transform: translate(0, 0);
  }


  /* ── Hero ── */
  .hero { padding: 100px 0 0; }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 24px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-title {
    font-family: var(--heading);
    font-size: 5.25rem;
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 0.98;
    margin: 0 0 28px;
    max-width: 1000px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-accent {
    color: var(--blue);
    font-weight: 500;
  }

  .hero-desc {
    font-size: 1.35rem;
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 720px;
    margin: 0 0 72px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  /* ── Stats ── */
  .stats-section { padding: 0 0 100px; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--text);
  }

  .stat-cell {
    padding: 36px 32px;
    border-right: 1px solid var(--border);
  }

  .stat-cell:last-child { border-right: none; }

  .stat-big {
    display: block;
    font-size: 4.5rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.04em;
    font-family: var(--mono);
    color: var(--text);
  }

  .stat-label {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    margin-top: 14px;
  }

  .stat-detail {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 4px;
    line-height: 1.5;
  }

  /* ── Memory comparison ── */
  .mem-section { padding: 100px 0; }

  .mem-toggles {
    display: flex;
    gap: 6px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .mem-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .mem-toggle:hover {
    color: var(--text);
    background: var(--nav-hover-bg);
  }

  .mem-toggle.active {
    color: var(--blue);
    background: color-mix(in srgb, var(--blue) 8%, transparent);
    border-color: color-mix(in srgb, var(--blue) 25%, transparent);
  }

  .mem-toggle-swatch {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .mem-toggle-swatch.go { background: #00ADD8; }
  .mem-toggle-swatch.node { background: #5FA04E; }
  .mem-toggle-swatch.python { background: #3776AB; }
  .mem-toggle-swatch.ruby { background: #CC342D; }

  .mem-toggle-count {
    font-family: var(--mono);
    font-size: 0.6875rem;
    opacity: 0.7;
  }

  .mem-bars {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .mem-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mem-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .mem-tool {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .mem-runtime-badge {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-left: 6px;
    padding: 2px 8px;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
    color: #00ADD8;
    background: rgba(0, 173, 216, 0.1);
  }

  .mem-val-info {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .mem-val {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .mem-val-dim {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--text) 35%, transparent);
  }

  .mem-track {
    height: 36px;
    display: flex;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
  }

  .mem-bar {
    height: 100%;
    transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }


  .bar-compose-containers {
    background: #2a2a3a;
    position: relative;
    display: flex;
    align-items: center;
  }

  .bar-compose-vm {
    background: #1D63ED;
    background-image: repeating-linear-gradient(45deg, transparent, transparent 6px, rgba(255,255,255,.15) 6px, rgba(255,255,255,.15) 12px);
    position: relative;
    display: flex;
    align-items: center;
  }

  .bar-label {
    font-family: var(--mono);
    font-size: 0.625rem;
    color: rgba(255, 255, 255, 0.7);
    padding-left: 10px;
    white-space: nowrap;
    overflow: hidden;
  }

  :global([data-theme="light"]) .bar-compose-containers { background: #11121a; }
  :global([data-theme="light"]) .bar-compose-vm {
    background: #1D63ED;
    background-image: repeating-linear-gradient(45deg, transparent, transparent 6px, rgba(255,255,255,.15) 6px, rgba(255,255,255,.15) 12px);
  }

  .bar-fuku-go { background: #00ADD8; }
  .bar-fuku-node { background: #5FA04E; }
  .bar-fuku-python { background: #3776AB; }
  .bar-fuku-ruby { background: #CC342D; }

  .mem-axis {
    margin-top: 12px;
    display: flex;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
  }

  /* ── When ── */
  .when-section { padding: 100px 0; }

  .when-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .when-card {
    padding: 28px 32px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--bg-card);
  }

  .when-complex {
    border-color: var(--blue);
    background: linear-gradient(180deg, color-mix(in srgb, var(--blue) 5%, transparent) 0%, transparent 100%);
    box-shadow: 0 20px 50px -30px color-mix(in srgb, var(--blue) 40%, transparent);
  }

  .when-kicker {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }

  .when-kicker.accent { color: var(--blue); }

  .when-card h3 {
    font-family: var(--heading);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 10px;
  }

  .when-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0 0 16px;
  }

  .when-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--border);
  }

  .when-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .when-list li {
    font-size: 0.95rem;
    line-height: 1.5;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .when-list .check {
    color: var(--blue);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── Tradeoffs table ── */
  .vs-section { padding: 100px 0; }

  .vs-table {
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-card);
    margin-top: 48px;
  }

  .vs-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 14px 28px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
  }

  .vs-header-accent { color: var(--blue); }

  .vs-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--border);
  }

  .vs-row-last { border-bottom: none; }

  .vs-cell {
    padding: 24px 28px;
  }

  .vs-cell:first-child {
    border-right: 1px solid var(--border);
  }

  .vs-cell-accent {
    background: color-mix(in srgb, var(--blue) 3%, transparent);
  }

  .vs-cell h4 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .vs-cell-accent h4 { color: var(--blue); }

  .vs-cell p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Feature matrix ── */
  .matrix-section { padding: 100px 0; }

  .matrix {
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-card);
    margin-top: 40px;
  }

  .mx-head, .mx-row, .mx-foot {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
    align-items: center;
    padding: 0 24px;
  }

  .mx-head {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding-top: 16px;
    padding-bottom: 16px;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }

  .mx-accent { color: var(--blue); }

  .mx-row {
    font-size: 0.875rem;
    padding-top: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }

  .mx-row:last-of-type { border-bottom: none; }

  .mx-alt {
    background: color-mix(in srgb, var(--text) 1.5%, transparent);
  }

  .mx-feat { font-weight: 500; color: var(--text); }

  .mx-y { color: var(--text); font-weight: 600; }

  .mx-n { color: color-mix(in srgb, var(--text) 25%, transparent); }

  .mx-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .mx-label.accent { color: var(--blue); font-weight: 600; }

  .mx-accent-y { color: var(--blue); }

  .mx-foot {
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 600;
    padding-top: 16px;
    padding-bottom: 16px;
    background: var(--text);
    color: var(--bg);
  }

  .mx-bad { color: #ff9b9b; }
  .mx-good { color: var(--blue); }

  /* ── CTA ── */
  .cta-section { padding: 0 0 100px; }

  .cta-card {
    padding: 56px;
    background: var(--text);
    color: var(--bg);
    border-radius: 18px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 32px;
    background-image: radial-gradient(circle at 90% 0%, color-mix(in srgb, var(--blue) 25%, transparent), transparent 50%);
  }

  .cta-eyebrow {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--blue);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .cta-title {
    font-family: var(--heading);
    font-size: 2.25rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 0;
    line-height: 1.1;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }

  .cta-btn-primary {
    padding: 14px 22px;
    border-radius: 10px;
    background: var(--bg);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .cta-btn-primary:hover { opacity: 0.9; text-decoration: none; }

  .cta-btn-ghost {
    padding: 14px 22px;
    border-radius: 10px;
    background: transparent;
    color: var(--bg);
    font-size: 0.875rem;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: border-color 0.15s;
  }

  .cta-btn-ghost:hover { border-color: rgba(255, 255, 255, 0.4); text-decoration: none; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .inner { padding: 0 24px; }

    .stats-grid { grid-template-columns: 1fr; }
    .stat-cell { border-right: none; border-bottom: 1px solid var(--border); }
    .stat-cell:last-child { border-bottom: none; }
    .stat-big { font-size: 3rem; }

    .when-grid { grid-template-columns: 1fr; }

    .vs-row { grid-template-columns: 1fr; }
    .vs-cell:first-child { border-right: none; border-bottom: 1px solid var(--border); }
    .vs-header { grid-template-columns: 1fr; gap: 4px; }

    .cta-card { grid-template-columns: 1fr; text-align: center; }
    .cta-actions { justify-content: center; }
  }

  @media (max-width: 768px) {
    .hero { padding: 56px 0 0; }
    .hero-title { font-size: 2.75rem; }
    .hero-desc { font-size: 1.05rem; margin-bottom: 48px; }

    .mem-toggles { gap: 4px; }
    .mem-toggle { font-size: 0.75rem; padding: 6px 10px; }
    .mem-toggle-count { display: none; }
    .mem-val-info { flex-direction: column; gap: 2px; }

    .matrix {
      margin-left: -24px; margin-right: -24px;
      border-radius: 0; border-left: none; border-right: none;
    }
    .mx-head, .mx-row, .mx-foot { font-size: 0.75rem; padding-left: 12px; padding-right: 12px; }

    .cta-card { padding: 40px 24px; }
    .cta-title { font-size: 1.5rem; }
  }
</style>

<script>
  function easeOutExpo(t: number): number {
    return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  // ── Count-up animation for [data-count] elements ──
  function animateCounters() {
    document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
      const target = parseInt(el.dataset.count!, 10);
      const suffix = el.dataset.suffix || "";

      if (target === 0) {
        el.textContent = "0" + suffix;
        return;
      }

      const duration = target > 10 ? 2000 : 600;
      let start: number | null = null;

      function step(timestamp: number) {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const current = Math.round(easeOutExpo(progress) * target);
        el.textContent = current + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) {
            observer.disconnect();
            requestAnimationFrame(step);
          }
        },
        { threshold: 0.5 }
      );
      observer.observe(el);
    });
  }

  // ── Scroll reveal for .reveal, .reveal-left, .reveal-right ──
  function initReveals() {
    const els = document.querySelectorAll<HTMLElement>(
      ".reveal, .reveal-left, .reveal-right"
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.dataset.delay || "0", 10);
            setTimeout(() => el.classList.add("visible"), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );

    els.forEach((el) => observer.observe(el));
  }

  // ── Memory bars – toggles + scroll-triggered grow ──
  function initMemBars() {
    const section = document.getElementById("mem-visual");
    if (!section) return;

    const maxMb = 5400;

    interface Runtime {
      composeMb: number;
      vmMb: number;
      fukuMb: number;
      composeLabel: string;
      fukuLabel: string;
      segments: { cls: string; mb: number; color: string }[];
    }

    const runtimes: Record<string, Runtime> = {
      go: {
        composeMb: 2000, vmMb: 2048, fukuMb: 60,
        composeLabel: "~2 GB containers", fukuLabel: "~60 MB total",
        segments: [{ cls: "bar-fuku-go", mb: 50, color: "#00ADD8" }],
      },
      node: {
        composeMb: 3500, vmMb: 2048, fukuMb: 2500,
        composeLabel: "~3.5 GB containers", fukuLabel: "~2.5 GB total",
        segments: [{ cls: "bar-fuku-node", mb: 2500, color: "#5FA04E" }],
      },
      python: {
        composeMb: 4500, vmMb: 2048, fukuMb: 3500,
        composeLabel: "~4.5 GB containers", fukuLabel: "~3.5 GB total",
        segments: [{ cls: "bar-fuku-python", mb: 3500, color: "#3776AB" }],
      },
      ruby: {
        composeMb: 6000, vmMb: 2048, fukuMb: 5000,
        composeLabel: "~6 GB containers", fukuLabel: "~5 GB total",
        segments: [{ cls: "bar-fuku-ruby", mb: 5000, color: "#CC342D" }],
      },
    };

    const composeBar = document.getElementById("mem-compose-bar")!;
    const vmBar = document.getElementById("mem-compose-vm")!;
    const fukuTrack = document.getElementById("mem-fuku-track")!;
    const composeVal = document.getElementById("mem-compose-val")!;
    const composeNote = document.getElementById("mem-compose-note")!;
    const fukuVal = document.getElementById("mem-fuku-val")!;
    const fukuNote = document.getElementById("mem-fuku-note")!;
    const badge = document.getElementById("mem-runtime-badge")!;

    const badgeColors: Record<string, { color: string; bg: string; label: string }> = {
      go:     { color: "#00ADD8", bg: "rgba(0, 173, 216, 0.1)",  label: "Go" },
      node:   { color: "#5FA04E", bg: "rgba(95, 160, 78, 0.1)",  label: "Node.js" },
      python: { color: "#3776AB", bg: "rgba(55, 118, 171, 0.1)", label: "Python" },
      ruby:   { color: "#CC342D", bg: "rgba(204, 52, 45, 0.1)",  label: "Ruby" },
    };

    function applyRuntime(key: string) {
      const r = runtimes[key];
      const scale = 8192;

      composeBar.style.width = (r.composeMb / scale) * 100 + "%";
      vmBar.style.width = (r.vmMb / scale) * 100 + "%";
      composeVal.textContent = r.composeLabel;
      composeNote.textContent = "+ ~2 GB Docker Desktop VM";
      fukuVal.textContent = r.fukuLabel;
      fukuNote.textContent = "No VM, no container runtime";

      const bc = badgeColors[key];
      badge.textContent = bc.label;
      badge.style.color = bc.color;
      badge.style.background = bc.bg;

      fukuTrack.innerHTML = "";
      for (const seg of r.segments) {
        const el = document.createElement("div");
        el.style.height = "100%";
        el.style.background = seg.color;
        el.style.width = "0";
        el.style.transition = "width 0.8s cubic-bezier(0.22, 1, 0.36, 1)";
        fukuTrack.appendChild(el);
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            el.style.width = (seg.mb / scale) * 100 + "%";
          });
        });
      }
    }

    const growObserver = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          growObserver.disconnect();
          requestAnimationFrame(() => {
            section.querySelectorAll<HTMLElement>("[data-target-width]").forEach((el) => {
              el.style.transition = "width 0.8s cubic-bezier(0.22, 1, 0.36, 1)";
              el.style.width = el.dataset.targetWidth!;
            });
          });
        }
      },
      { threshold: 0.3 }
    );
    growObserver.observe(section);

    document.getElementById("mem-toggles")!.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".mem-toggle");
      if (!btn || btn.classList.contains("active")) return;

      document.querySelectorAll(".mem-toggle").forEach((t) => t.classList.remove("active"));
      btn.classList.add("active");

      applyRuntime(btn.dataset.runtime!);
    });

  }

  animateCounters();
  initReveals();
  initMemBars();
</script>
