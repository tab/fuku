---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Why fuku - fuku"
  description="When to use fuku, how it compares to Docker Compose, Foreman, and Overmind, and why it exists."
>
  <Header section="why" />

  <main>
    <!-- ─── Hero ─── -->
    <section class="hero">
      <div class="container">
        <p class="hero-eyebrow">Local development orchestrator</p>
        <h1 class="hero-title">
          Why fuku
        </h1>
        <p class="hero-desc">
          Run all your services as native processes with proper startup ordering,<br class="hide-mobile"/>
          readiness checks, and a live dashboard. No Docker required.
        </p>
      </div>
    </section>

    <!-- ─── The number ─── -->
    <section class="bignum-section">
      <div class="container">
        <div class="bignum-grid">
          <div class="bignum-card glass-card reveal" data-delay="0">
            <span class="bignum gradient-text" data-count="30" data-suffix="x">0x</span>
            <span class="bignum-label">less memory than Compose</span>
            <span class="bignum-detail">~60 MB vs ~2 GB for 50 services</span>
          </div>
          <div class="bignum-card glass-card reveal" data-delay="100">
            <span class="bignum gradient-text" data-count="0">0</span>
            <span class="bignum-label">Docker dependencies</span>
            <span class="bignum-detail">Native processes, no VM, no daemon</span>
          </div>
          <div class="bignum-card glass-card reveal" data-delay="200">
            <span class="bignum gradient-text" data-count="1">1</span>
            <span class="bignum-label">command to start everything</span>
            <span class="bignum-detail">Tier-based ordering with readiness checks</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Memory visual ─── -->
    <section class="mem-section">
      <div class="container narrow">
        <div class="section-header center">
          <span class="section-label">Resource usage</span>
          <h2>Memory comparison</h2>
        </div>

        <div class="mem-visual glass-card reveal" id="mem-visual">
          <div class="mem-tabs" id="mem-tabs">
            <button class="mem-tab active" data-runtime="go">Go<span class="mem-tab-count">50 services</span></button>
            <button class="mem-tab" data-runtime="node">Node.js<span class="mem-tab-count">30 services</span></button>
            <button class="mem-tab" data-runtime="python">Python<span class="mem-tab-count">20 services</span></button>
            <button class="mem-tab" data-runtime="ruby">Ruby<span class="mem-tab-count">15 services</span></button>
          </div>

          <div class="mem-bars">
            <div class="mem-row">
              <div class="mem-label">
                <span class="mem-tool">Docker Compose</span>
                <span class="mem-val" id="mem-compose-val">0 MB</span>
              </div>
              <div class="mem-track">
                <div class="mem-bar bar-compose bar-paused" id="mem-compose-bar"></div>
              </div>
              <span class="mem-footnote" id="mem-compose-note">+ Docker Desktop VM: 2-4 GB</span>
            </div>
            <div class="mem-row">
              <div class="mem-label">
                <span class="mem-tool highlight">fuku</span>
                <span class="mem-val highlight" id="mem-fuku-val">0 MB</span>
              </div>
              <div class="mem-track">
                <div class="mem-bar bar-fuku bar-paused" id="mem-fuku-bar"></div>
              </div>
              <span class="mem-footnote" id="mem-fuku-note">No VM, no container runtime</span>
            </div>
          </div>

          <p class="mem-estimate" id="mem-estimate"></p>
        </div>
      </div>
    </section>

    <!-- ─── When to use ─── -->
    <section class="when-section">
      <div class="container narrow">
        <div class="section-header center">
          <span class="section-label">Use cases</span>
          <h2>When to use fuku</h2>
        </div>

        <div class="when-cards">
          <div class="glass-card when-card reveal-left">
            <div class="when-stripe stripe-red"></div>
            <div class="when-body">
              <span class="when-badge badge-red">Keep it simple</span>
              <p class="when-quote">A backend and a frontend. Two terminal tabs. Done.</p>
              <p class="when-verdict">You don't need fuku.</p>
            </div>
          </div>
          <div class="when-arrow reveal" data-delay="150">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
          <div class="glass-card when-card when-card-yes reveal-right">
            <div class="when-stripe stripe-green"></div>
            <div class="when-body">
              <span class="when-badge badge-green">complex configuration</span>
              <ul class="when-list">
                <li>Multiple backend services with dependencies</li>
                <li>BFF layer between APIs and the UI</li>
                <li>Several frontends — SPA, docs, Swagger</li>
                <li>Gateways, mock servers, infrastructure</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Problem → Solution ─── -->
    <section class="vs-section">
      <div class="container">
        <div class="section-header center">
          <span class="section-label">Docker Compose vs fuku</span>
          <h2>Local development tradeoffs</h2>
          <p class="section-sub">Compose runs containers. fuku runs native processes. Here's what that means day to day.</p>
        </div>

        <div class="vs-grid">
          <div class="vs-pair reveal" data-delay="0">
            <div class="vs-problem">
              <div class="vs-icon vs-icon-red">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
              </div>
              <div>
                <h3>~2 GB+ container memory</h3>
                <p>Plus 2-4 GB for the Docker Desktop VM on macOS</p>
              </div>
            </div>
            <div class="vs-solution">
              <div class="vs-icon vs-icon-blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3>~60 MB total</h3>
                <p>Native processes. No VM, no daemon, no overhead.</p>
              </div>
            </div>
          </div>

          <div class="vs-pair reveal" data-delay="80">
            <div class="vs-problem">
              <div class="vs-icon vs-icon-red">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <h3>Minutes to start</h3>
                <p>Image pulls, layer extraction, network setup, cgroup init</p>
              </div>
            </div>
            <div class="vs-solution">
              <div class="vs-icon vs-icon-blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3>Seconds to start</h3>
                <p>Native fork and exec. No container initialization.</p>
              </div>
            </div>
          </div>

          <div class="vs-pair reveal" data-delay="160">
            <div class="vs-problem">
              <div class="vs-icon vs-icon-red">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
              </div>
              <div>
                <h3>Broken file watching</h3>
                <p>macOS VM proxies FS events. Latency. Missed changes.</p>
              </div>
            </div>
            <div class="vs-solution">
              <div class="vs-icon vs-icon-blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3>Instant hot-reload</h3>
                <p>Native fsnotify. Debounced. Configurable per-service.</p>
              </div>
            </div>
          </div>

          <div class="vs-pair reveal" data-delay="240">
            <div class="vs-problem">
              <div class="vs-icon vs-icon-red">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
              </div>
              <div>
                <h3>depends_on ≠ ready</h3>
                <p>Container started doesn't mean service is accepting requests</p>
              </div>
            </div>
            <div class="vs-solution">
              <div class="vs-icon vs-icon-blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3>Real readiness gates</h3>
                <p>HTTP, TCP, and log pattern checks. Tier-based startup ordering.</p>
              </div>
            </div>
          </div>

          <div class="vs-pair reveal" data-delay="320">
            <div class="vs-problem">
              <div class="vs-icon vs-icon-red">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              </div>
              <div>
                <h3>Interleaved log noise</h3>
                <p>No overview. No controls. grep your way through stdout.</p>
              </div>
            </div>
            <div class="vs-solution">
              <div class="vs-icon vs-icon-blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <h3>Live TUI dashboard</h3>
                <p>Per-service status, CPU/memory, restart controls, log filtering.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Comparison table ─── -->
    <section class="table-section">
      <div class="container">
        <div class="section-header center">
          <span class="section-label">Comparison</span>
          <h2>Feature matrix</h2>
        </div>

        <div class="table-wrap glass-card reveal">
          <table class="cmp">
            <thead>
              <tr>
                <th class="fc"></th>
                <th>Foreman</th>
                <th>Overmind</th>
                <th>Compose</th>
                <th class="hl">fuku</th>
              </tr>
            </thead>
            <tbody>
              <tr><td class="fc">Native processes</td><td><span class="ic y"></span></td><td><span class="ic y"></span></td><td><span class="ic n"></span><span class="tn">Containers</span></td><td class="hl"><span class="ic y"></span></td></tr>
              <tr><td class="fc">Startup ordering</td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td><span class="ic p"></span><span class="tn">depends_on</span></td><td class="hl"><span class="ic y"></span><span class="tn">Tier-based</span></td></tr>
              <tr><td class="fc">Readiness checks</td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td><span class="ic p"></span><span class="tn">Extra config</span></td><td class="hl"><span class="ic y"></span><span class="tn">HTTP, TCP, log</span></td></tr>
              <tr><td class="fc">Interactive TUI</td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td class="hl"><span class="ic y"></span></td></tr>
              <tr><td class="fc">CPU/memory monitoring</td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td><span class="ic p"></span><span class="tn">docker stats</span></td><td class="hl"><span class="ic y"></span><span class="tn">Built-in</span></td></tr>
              <tr><td class="fc">Hot-reload</td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td><span class="ic p"></span><span class="tn">Volume mounts</span></td><td class="hl"><span class="ic y"></span><span class="tn">Built-in</span></td></tr>
              <tr><td class="fc">Service profiles</td><td><span class="ic n"></span></td><td><span class="ic n"></span></td><td><span class="ic y"></span></td><td class="hl"><span class="ic y"></span></td></tr>
              <tr><td class="fc">Per-process terminal</td><td><span class="ic n"></span></td><td><span class="ic y"></span><span class="tn">tmux</span></td><td><span class="ic p"></span><span class="tn">docker exec</span></td><td class="hl"><span class="ic n"></span></td></tr>
              <tr><td class="fc">Log streaming</td><td><span class="ic p"></span><span class="tn">stdout</span></td><td><span class="ic p"></span><span class="tn">stdout</span></td><td><span class="ic p"></span><span class="tn">docker logs</span></td><td class="hl"><span class="ic y"></span><span class="tn">Socket-based</span></td></tr>
              <tr><td class="fc">Config format</td><td><span class="tl">Procfile</span></td><td><span class="tl">Procfile</span></td><td><span class="tl">YAML</span></td><td class="hl"><span class="tl">YAML</span></td></tr>
              <tr><td class="fc">Requires Docker</td><td><span class="ic y"></span><span class="tn">No</span></td><td><span class="ic y"></span><span class="tn">No</span></td><td><span class="ic n"></span><span class="tn">Required</span></td><td class="hl"><span class="ic y"></span><span class="tn">No</span></td></tr>
            </tbody>
            <tfoot>
              <tr><td class="fc">Memory (~50 services)</td><td><span class="mv">~60 MB</span></td><td><span class="mv">~60 MB</span></td><td><span class="mv bad">~2 GB+</span></td><td class="hl"><span class="mv good">~60 MB</span></td></tr>
            </tfoot>
          </table>
        </div>
      </div>
    </section>

    <!-- ─── CTA ─── -->
    <section class="cta-section">
      <div class="container narrow">
        <div class="cta-card glass-card reveal">
          <h2 class="cta-title">Try it out</h2>
          <p class="cta-desc">Add a <code>fuku.yaml</code> to your project, list your services, and run <code>fuku</code>.</p>
          <div class="cta-actions">
            <a href={`${base}docs/getting-started/`} class="btn btn-primary">Getting started</a>
            <a href={`${base}docs/configuration/`} class="btn btn-secondary">Configuration</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Layout ── */
  .container { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }
  .narrow { max-width: 860px; }

  .section-header { margin-bottom: 36px; }
  .section-header.center { text-align: center; }

  .section-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
    margin-bottom: 10px;
  }

  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
  }

  .center .section-sub { max-width: 520px; margin: 0 auto; }

  .hide-mobile { display: inline; }

  /* ── Glass card ── */
  .glass-card {
    position: relative;
    background: var(--glass-card-bg);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border: 1px solid var(--glass-card-border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.35s cubic-bezier(0.22, 1, 0.36, 1),
                border-color 0.35s ease;
  }

  .glass-card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 50%;
    border-radius: 16px 16px 0 0;
    background: linear-gradient(180deg, var(--glass-card-shine) 0%, transparent 100%);
    pointer-events: none;
  }

  .glass-card::after {
    content: ""; position: absolute; inset: 0; border-radius: 16px; padding: 1px;
    background: linear-gradient(180deg, var(--glass-card-ring-top) 0%, transparent 40%, transparent 60%, var(--glass-card-ring-bottom) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;
  }

  .gradient-text {
    background: var(--gradient);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  @keyframes gradient-shift {
    0% { background-position: 0% center; }
    50% { background-position: 100% center; }
    100% { background-position: 0% center; }
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bar-grow { from { width: 0 !important; } }

  /* ── Scroll reveals ── */
  .reveal,
  .reveal-left,
  .reveal-right {
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal { transform: translateY(24px); }
  .reveal-left { transform: translateX(-32px); }
  .reveal-right { transform: translateX(32px); }

  .reveal.visible,
  .reveal-left.visible,
  .reveal-right.visible {
    opacity: 1;
    transform: translate(0, 0);
  }

  .bar-paused {
    width: 0 !important;
  }

  /* ── Hero ── */
  .hero {
    padding: 80px 0 48px;
    text-align: center;
  }

  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
    margin-bottom: 20px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-title {
    font-size: 3.8rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin-bottom: 20px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-desc {
    font-size: 1.12rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 36px;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }

  /* ── Big numbers ── */
  .bignum-section {
    padding: 0 0 72px;
  }

  .bignum-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .bignum-card {
    padding: 32px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .bignum-card:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: var(--glass-card-hover-border);
    box-shadow: var(--glass-card-shadow);
  }

  .bignum {
    font-size: 3.2rem;
    font-weight: 800;
    font-family: var(--mono);
    letter-spacing: -0.04em;
    line-height: 1;
    position: relative;
  }

  .bignum-label {
    font-size: 0.82rem;
    color: var(--text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    position: relative;
    margin-top: 4px;
  }

  .bignum-detail {
    font-size: 0.78rem;
    color: var(--text-muted);
    position: relative;
  }

  /* ── Memory bars ── */
  .mem-section {
    padding: 72px 0;
    background: var(--bg-elevated);
  }

  .mem-visual {
    padding: 36px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .mem-visual:hover { transform: none; }

  .mem-tabs {
    display: flex;
    gap: 6px;
    position: relative;
  }

  .mem-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }

  .mem-tab:hover {
    color: var(--text);
    background: var(--nav-hover-bg);
  }

  .mem-tab.active {
    color: var(--blue);
    background: rgba(91, 140, 254, 0.08);
    border-color: rgba(91, 140, 254, 0.25);
  }

  .mem-tab-count {
    font-size: 0.68rem;
    font-weight: 500;
    opacity: 0.7;
  }

  .mem-bars {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .mem-row {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mem-label {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .mem-tool {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .mem-tool.highlight {
    color: var(--blue);
  }

  .mem-val {
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--mono);
    white-space: nowrap;
    color: var(--text);
    transition: opacity 0.15s;
  }

  .mem-val.highlight {
    color: var(--blue);
  }

  .mem-track {
    height: 36px;
    border-radius: 10px;
    background: var(--code-bg);
    overflow: hidden;
  }

  .mem-bar {
    height: 100%;
    border-radius: 10px;
    transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bar-compose {
    width: 100%;
    background: linear-gradient(90deg, rgba(249, 226, 175, 0.5) 0%, rgba(249, 226, 175, 0.2) 100%);
    border: 1px solid rgba(249, 226, 175, 0.45);
  }

  .bar-fuku {
    width: 5%;
    min-width: 40px;
    background: linear-gradient(90deg, rgba(90, 247, 142, 0.3) 0%, rgba(90, 247, 142, 0.1) 100%);
    border: 1px solid rgba(90, 247, 142, 0.25);
  }

  .mem-footnote {
    font-size: 0.72rem;
    color: var(--text-muted);
