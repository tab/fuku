</style>

<script>
  function easeOutExpo(t: number): number {
    return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  // ── Count-up animation for [data-count] elements ──
  function animateCounters() {
    document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
      const target = parseInt(el.dataset.count!, 10);
      const suffix = el.dataset.suffix || "";

      if (target === 0) {
        el.textContent = "0" + suffix;
        return;
      }

      const duration = target > 10 ? 2000 : 600;
      let start: number | null = null;

      function step(timestamp: number) {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const current = Math.round(easeOutExpo(progress) * target);
        el.textContent = current + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) {
            observer.disconnect();
            requestAnimationFrame(step);
          }
        },
        { threshold: 0.5 }
      );
      observer.observe(el);
    });
  }

  // ── Scroll reveal for .reveal, .reveal-left, .reveal-right ──
  function initReveals() {
    const els = document.querySelectorAll<HTMLElement>(
      ".reveal, .reveal-left, .reveal-right"
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = parseInt(el.dataset.delay || "0", 10);
            setTimeout(() => el.classList.add("visible"), delay);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15 }
    );

    els.forEach((el) => observer.observe(el));
  }

  // ── Memory bars + value count-up ──
  function initMemBars() {
    const section = document.getElementById("mem-visual");
    if (!section) return;

    const runtimes: Record<string, {
      composeMB: number;
      fukuMB: number;
      composeNote: string;
      fukuNote: string;
      estimate: string;
    }> = {
      go: {
        composeMB: 2048,
        fukuMB: 60,
        composeNote: "+ Docker Desktop VM: 2-4 GB",
        fukuNote: "No VM, no container runtime",
        estimate: "",
      },
      node: {
        composeMB: 6400,
        fukuMB: 2400,
        composeNote: "+ Docker Desktop VM: 2-4 GB",
        fukuNote: "No VM, no container runtime",
        estimate: "Rough estimate: ~80 MB per Express service",
      },
      python: {
        composeMB: 5000,
        fukuMB: 2000,
        composeNote: "+ Docker Desktop VM: 2-4 GB",
        fukuNote: "No VM, no container runtime",
        estimate: "Rough estimate: ~100 MB per FastAPI service",
      },
      ruby: {
        composeMB: 5250,
        fukuMB: 2250,
        composeNote: "+ Docker Desktop VM: 2-4 GB",
        fukuNote: "No VM, no container runtime",
        estimate: "Rough estimate: ~150 MB per Rails service (Puma single-mode)",
      },
    };

    const composeVal = document.getElementById("mem-compose-val")!;
    const fukuVal = document.getElementById("mem-fuku-val")!;
    const composeBar = document.getElementById("mem-compose-bar")!;
    const fukuBar = document.getElementById("mem-fuku-bar")!;
    const composeNote = document.getElementById("mem-compose-note")!;
    const fukuNote = document.getElementById("mem-fuku-note")!;
    const estimateEl = document.getElementById("mem-estimate")!;

    function formatMB(mb: number): string {
      if (mb >= 1024) return "~" + (mb / 1024).toFixed(1).replace(/\.0$/, "") + " GB";
      return "~" + mb + " MB";
    }

    function animateValue(el: HTMLElement, from: number, to: number) {
      const duration = 1200;
      let start: number | null = null;

      function step(timestamp: number) {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const current = Math.round(from + easeOutExpo(progress) * (to - from));
        el.textContent = formatMB(current);
        if (progress < 1) requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    }

    let currentCompose = 0;
    let currentFuku = 0;
    let activated = false;

    function setRuntime(key: string, animate: boolean) {
      const data = runtimes[key];
      const maxMB = Math.max(...Object.values(runtimes).map((r) => r.composeMB));

      const composePct = (data.composeMB / maxMB) * 100;
      const fukuPct = Math.max((data.fukuMB / maxMB) * 100, 3);

      if (animate) {
        animateValue(composeVal, currentCompose, data.composeMB);
        animateValue(fukuVal, currentFuku, data.fukuMB);
      } else {
        composeVal.textContent = formatMB(data.composeMB);
        fukuVal.textContent = formatMB(data.fukuMB);
      }

      composeBar.classList.remove("bar-paused");
      fukuBar.classList.remove("bar-paused");
      composeBar.style.width = composePct + "%";
      fukuBar.style.width = fukuPct + "%";

      composeNote.textContent = data.composeNote;
      fukuNote.textContent = data.fukuNote;
      estimateEl.textContent = data.estimate;

      currentCompose = data.composeMB;
      currentFuku = data.fukuMB;
    }

    // Tab clicks
    document.getElementById("mem-tabs")!.addEventListener("click", (e) => {
      const tab = (e.target as HTMLElement).closest<HTMLElement>(".mem-tab");
      if (!tab || tab.classList.contains("active")) return;

      section.querySelectorAll(".mem-tab").forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");

      setRuntime(tab.dataset.runtime!, true);
    });

    // Scroll trigger
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !activated) {
          activated = true;
          observer.disconnect();
          animateValue(composeVal, 0, runtimes.go.composeMB);
          animateValue(fukuVal, 0, runtimes.go.fukuMB);

          const maxMB = Math.max(...Object.values(runtimes).map((r) => r.composeMB));
          composeBar.classList.remove("bar-paused");
          fukuBar.classList.remove("bar-paused");
          composeBar.style.width = (runtimes.go.composeMB / maxMB) * 100 + "%";
          fukuBar.style.width = Math.max((runtimes.go.fukuMB / maxMB) * 100, 3) + "%";

          currentCompose = runtimes.go.composeMB;
          currentFuku = runtimes.go.fukuMB;
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(section);
  }

  animateCounters();
  initReveals();
  initMemBars();
</script>
