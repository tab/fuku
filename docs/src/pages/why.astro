    .mem-tabs { gap: 4px; }
    .mem-tab { font-size: 0.78rem; padding: 8px 6px; }
    .mem-tab-count { font-size: 0.6rem; }
    .mem-val { font-size: 0.95rem; }

    .when-cards { flex-direction: column; }
    .when-arrow { justify-content: center; transform: rotate(90deg); }

    .table-wrap {
      margin-left: -24px; margin-right: -24px;
